{
    "name": "revit-mcp-bim",
    "version": "2.2.0",
    "description": "MCP server for BIM-focused Revit workflows — OMA-style toolset built on top of revit-mcp-server",
    "main": "./build/index.js",
    "type": "module",
    "bin": {
        "revit-mcp-bim": "./build/index.js"
    },
    "scripts": {
        "clean": "rimraf build",
        "prebuild": "npm run clean",
        "build": "node esbuild.config.mjs && node generate-tool-schemas.mjs && node deploy-addins.mjs",
        "build:check": "tsc --noEmit",
        "prepublishOnly": "npm run build"
    },
    "files": [
        "build",
        "README.md"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/REDI1995/revit-mcp-server-BIM.git"
    },
    "keywords": [
        "mcp",
        "revit",
        "autodesk",
        "claude",
        "ai",
        "bim",
        "architecture"
    ],
    "license": "MIT",
    "engines": {
        "node": ">=18"
    },
    "publishConfig": {
        "access": "public"
    },
    "bugs": {
        "url": "https://github.com/REDI1995/revit-mcp-server-BIM/issues"
    },
    "homepage": "https://github.com/REDI1995/revit-mcp-server-BIM#readme",
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.7.0",
        "better-sqlite3": "^12.11.1",
        "zod": "^3.24.2"
    },
    "devDependencies": {
        "@types/better-sqlite3": "^7.6.13",
        "@types/node": "^22.13.10",
        "esbuild": "^0.28.0",
        "rimraf": "^5.0.10",
        "typescript": "^5.8.2"
    }
}
